#!/bin/sh
# VLESS + XTLS-Vision 极简部署脚本 for 128MB 低内存设备
# 适用于 Alpine Linux 3.22

set -e

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}  VLESS + XTLS-Vision 一键部署脚本${NC}"
echo -e "${GREEN}  适用于 128MB 内存设备${NC}"
echo -e "${GREEN}========================================${NC}"

# ========== 配置部分（按需修改）==========
# 监听端口（默认443，如有冲突可改为其他端口）
PORT="${PORT:-443}"
# UUID（如果不提供则自动生成）
UUID="${UUID:-}"
# 伪装域名 SNI（建议使用常用大网站）
SNI="${SNI:-www.microsoft.com}"
# 证书目录
CERT_DIR="${CERT_DIR:-/etc/xray/certs}"
# =======================================

# 如果没有提供 UUID，自动生成一个
if [ -z "$UUID" ]; then
    if command -v uuidgen >/dev/null 2>&1; then
        UUID=$(uuidgen | tr '[:upper:]' '[:lower:]')
    elif [ -f /proc/sys/kernel/random/uuid ]; then
        UUID=$(cat /proc/sys/kernel/random/uuid)
    else
        # 降级方案：生成一个简单但有效的 UUID 格式
        UUID=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || echo "8a4e5e3e-2b9c-4f6d-8f1a-3e7c9d2b4a6f")
    fi
fi

echo -e "${YELLOW}[1/6] 检测 CPU 架构...${NC}"
# 检测 CPU 架构并下载对应版本
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)  XRAY_ARCH="64" ;;
    aarch64) XRAY_ARCH="arm64-v8a" ;;
    armv7l)  XRAY_ARCH="arm32-v7a" ;;
    i686)    XRAY_ARCH="32" ;;
    *)       echo -e "${RED}不支持的架构: $ARCH${NC}"; exit 1 ;;
esac
echo -e "${GREEN}检测到架构: $ARCH -> Xray 版本: $XRAY_ARCH${NC}"

echo -e "${YELLOW}[2/6] 安装依赖...${NC}"
apk update --quiet
apk add --no-cache wget ca-certificates unzip --quiet

echo -e "${YELLOW}[3/6] 下载 Xray-core...${NC}"
# 获取最新版本号
LATEST_VERSION=$(wget -qO- https://api.github.com/repos/XTLS/Xray-core/releases/latest | grep -o '"tag_name": "[^"]*"' | cut -d'"' -f4)
if [ -z "$LATEST_VERSION" ]; then
    LATEST_VERSION="v1.8.24"  # 降级版本
fi
echo -e "最新版本: ${LATEST_VERSION}"

DOWNLOAD_URL="https://github.com/XTLS/Xray-core/releases/download/${LATEST_VERSION}/Xray-linux-${XRAY_ARCH}.zip"
echo -e "下载地址: ${DOWNLOAD_URL}"

# 下载并解压
wget -q --show-progress -O /tmp/xray.zip "$DOWNLOAD_URL"
mkdir -p /usr/local/xray
unzip -q /tmp/xray.zip -d /usr/local/xray
chmod +x /usr/local/xray/xray
rm -f /tmp/xray.zip

echo -e "${YELLOW}[4/6] 生成 TLS 证书...${NC}"
mkdir -p "$CERT_DIR"

# 生成自签名证书（如无法联网或不想使用域名）
# 这是低内存设备的推荐方案，避免运行 acme.sh
openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:prime256v1 \
    -keyout "$CERT_DIR/private.key" \
    -out "$CERT_DIR/certificate.crt" \
    -days 3650 -nodes -subj "/CN=$SNI" 2>/dev/null

echo -e "${GREEN}证书已生成: $CERT_DIR/certificate.crt${NC}"

echo -e "${YELLOW}[5/6] 生成 Xray 配置文件...${NC}"
mkdir -p /usr/local/xray/config

cat > /usr/local/xray/config/config.json << 'EOF'
{
    "log": {
        "loglevel": "warning",
        "access": "none",
        "error": "none"
    },
    "inbounds": [
        {
            "listen": "0.0.0.0",
            "port": PORT_PLACEHOLDER,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "UUID_PLACEHOLDER",
                        "flow": "xtls-rprx-vision"
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "tcp",
                "security": "tls",
                "tlsSettings": {
                    "serverName": "SNI_PLACEHOLDER",
                    "rejectUnknownSni": false,
                    "minVersion": "1.2",
                    "certificates": [
                        {
                            "certificateFile": "/etc/xray/certs/certificate.crt",
                            "keyFile": "/etc/xray/certs/private.key"
                        }
                    ]
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": ["http", "tls"]
            }
        }
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
    ],
    "policy": {
        "levels": {
            "0": {
                "handshake": 2,
                "connIdle": 120
            }
        }
    }
}
EOF

# 替换占位符
sed -i "s/PORT_PLACEHOLDER/${PORT}/g" /usr/local/xray/config/config.json
sed -i "s/UUID_PLACEHOLDER/${UUID}/g" /usr/local/xray/config/config.json
sed -i "s/SNI_PLACEHOLDER/${SNI}/g" /usr/local/xray/config/config.json

echo -e "${YELLOW}[6/6] 创建开机自启服务...${NC}"

# 创建 OpenRC 服务脚本（Alpine 专用）
cat > /etc/init.d/xray << 'EOF'
#!/sbin/openrc-run

name="xray"
description="Xray Proxy Service"
command="/usr/local/xray/xray"
command_args="run -config /usr/local/xray/config/config.json"
command_user="root"
pidfile="/run/${RC_SVCNAME}.pid"
command_background=true

depend() {
    need net
}
EOF

chmod +x /etc/init.d/xray

# 启动服务
rc-service xray start
rc-update add xray default

echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}         部署完成！${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""
echo -e "${YELLOW}📋 客户端配置信息：${NC}"
echo -e "协议: ${GREEN}vless${NC}"
echo -e "地址: $(hostname -i | awk '{print $1}')"
echo -e "端口: ${GREEN}${PORT}${NC}"
echo -e "UUID: ${GREEN}${UUID}${NC}"
echo -e "Flow: ${GREEN}xtls-rprx-vision${NC}"
echo -e "SNI: ${GREEN}${SNI}${NC}"
echo -e "传输: ${GREEN}tcp${NC}"
echo -e "安全: ${GREEN}tls${NC}"
echo ""
echo -e "${YELLOW}🔗 VLESS 链接（可直接导入客户端）：${NC}"
VLESS_LINK="vless://${UUID}@$(hostname -i | awk '{print $1}'):${PORT}?type=tcp&security=tls&sni=${SNI}&flow=xtls-rprx-vision&fp=chrome#Alpine_VLESS"
echo -e "${GREEN}${VLESS_LINK}${NC}"
echo ""
echo -e "${YELLOW}💡 常用管理命令：${NC}"
echo -e "  启动: ${GREEN}rc-service xray start${NC}"
echo -e "  停止: ${GREEN}rc-service xray stop${NC}"
echo -e "  重启: ${GREEN}rc-service xray restart${NC}"
echo -e "  状态: ${GREEN}rc-service xray status${NC}"
echo -e "  日志: ${GREEN}cat /usr/local/xray/xray.log${NC}"
echo ""
echo -e "${YELLOW}📂 重要文件位置：${NC}"
echo -e "  程序: /usr/local/xray/xray"
echo -e "  配置: /usr/local/xray/config/config.json"
echo -e "  证书: $CERT_DIR/"
echo ""
echo -e "${RED}⚠️  内存优化提醒：${NC}"
echo -e "  1. 当前证书为自签名，部分客户端需要手动信任"
echo -e "  2. 如需公网访问，请配置防火墙开放端口 ${PORT}"
echo -e "  3. 建议在客户端设置中关闭 MUX 多路复用"
